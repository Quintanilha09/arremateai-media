# =============================================================
# arremateai-media — Variáveis de Ambiente
# =============================================================
# Copie este arquivo para .env e ajuste os valores conforme o ambiente.

# --- Servidor ---
SERVER_PORT=8083

# --- URLs e armazenamento ---
MEDIA_BASE_URL=http://localhost:8083
MEDIA_STORAGE_LOCATION=./uploads

# --- Limites de arquivos (bytes) ---
MEDIA_MAX_IMAGE_SIZE=5242880
MEDIA_MAX_VIDEO_SIZE=524288000
MEDIA_MAX_AVATAR_SIZE=2097152
